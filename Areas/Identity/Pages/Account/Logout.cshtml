@page
@model LogoutModel
@{
    ViewData["Title"] = "Déconnexion";
}

<div class="row justify-content-center">
    <div class="col-md-5 text-center">
        <h2 class="mb-4">Vous êtes déconnecté</h2>
        <p class="text-muted">Merci d'avoir utilisé l'application.</p>

        <a asp-page="./Login" class="btn btn-primary mt-3">Se reconnecter</a>
    </div>
</div>